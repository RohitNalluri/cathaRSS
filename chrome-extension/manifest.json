{
  "manifest_version": 3,
  "name": "Read It All — Obsidian Clipper",
  "version": "1.0.0",
  "description": "Clip any webpage or Substack article directly into your Obsidian vault.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
